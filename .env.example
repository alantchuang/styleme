# Copy this file to .env.local and fill in your own values.
# See docs/EnvironmentBootstrap.md for a full setup walkthrough.

# ── Clerk ────────────────────────────────────────────────────────────────────
# Create a Clerk application at https://clerk.com
# Set minimum sign-up age to 13 in Clerk → User & Authentication → Restrictions
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...your-publishable-key...
CLERK_SECRET_KEY=sk_test_...your-secret-key...

# ── Convex ───────────────────────────────────────────────────────────────────
# These are written automatically by `npx convex dev` on first run.
# You can leave them blank until you run that command.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site
CONVEX_DEPLOYMENT=dev:your-deployment-name

# ── Server-side API keys ─────────────────────────────────────────────────────
# These must ALSO be set as Convex environment variables so Convex actions can
# read them. After filling in the values below, run:
#
#   npx convex env set ANTHROPIC_API_KEY sk-ant-...
#   npx convex env set CLERK_SECRET_KEY  sk_test_...
#   npx convex env set PEXELS_API_KEY    ...
#
ANTHROPIC_API_KEY=sk-ant-...your-key...
PEXELS_API_KEY=...your-pexels-key...

# ── E2E test accounts (Playwright only) ──────────────────────────────────────
# Create two Clerk accounts to use as test fixtures.
# Find each user's Clerk ID in the Clerk dashboard → Users.
E2E_USER_A_EMAIL=test-a@example.com
E2E_USER_A_PASSWORD=your-test-password
E2E_USER_A_CLERK_ID=user_...
E2E_USER_B_EMAIL=test-b@example.com
E2E_USER_B_PASSWORD=your-test-password
E2E_USER_B_CLERK_ID=user_...
